@model BaiTap8.Models.Student

<h2>Chi tiết sinh viên</h2>

<h4>@Model.Name</h4>

<p>
    Tuổi: @Model.Age
</p>

@if (Model.Images != null)
{
    foreach (var img in Model.Images)
    {
        <img src="@img.ImageUrl"
             width="150"
             class="m-1 border" />
    }
}

<br />
<br />

<a asp-action="Index"
   class="btn btn-secondary">
    Quay lại
</a>