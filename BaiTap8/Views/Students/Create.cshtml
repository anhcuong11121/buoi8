@model BaiTap8.Models.Student

<h2>Thêm sinh viên</h2>

<form asp-action="Create"
      method="post"
      enctype="multipart/form-data">

    <div class="mb-3">
        <label>Tên</label>
        <input asp-for="Name"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Tuổi</label>
        <input asp-for="Age"
               class="form-control" />
    </div>

    <div class="mb-3">
        <input type="file"
               name="files"
               multiple
               class="form-control" />
    </div>

    <button class="btn btn-success">
        Lưu
    </button>

</form>