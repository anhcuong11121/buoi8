@model BaiTap8.Models.Product

<h2>Xóa sản phẩm</h2>

<div class="alert alert-danger">
    Bạn có chắc muốn xóa?
</div>

<form asp-action="Delete">

    <input asp-for="Id" type="hidden" />

    <button class="btn btn-danger">
        Xóa
    </button>

    <a asp-action="Index"
       class="btn btn-secondary">
        Hủy
    </a>

</form>